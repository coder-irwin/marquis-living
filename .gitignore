# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies (match at any depth, incl. nested projects like akaash-site/)
node_modules/
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js (match at any depth)
.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# python (scripts/)
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/

# build output of nested designs
/dist
out/

# large media / scratch assets (too big for git — keep out of repo)
*.mp4
*.mov
*.zip
